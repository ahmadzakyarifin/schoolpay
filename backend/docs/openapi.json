{
  "openapi": "3.0.3",
  "info": {
    "title": "SchoolPay API",
    "version": "0.1.0-mvp",
    "description": "Release-readiness OpenAPI contract for SchoolPay auth, finance, notification, and support chat modules."
  },
  "servers": [
    {
      "url": "http://localhost:8080/api",
      "description": "Local API"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "PaymentRequest": {
        "type": "object",
        "required": [
          "student_id",
          "amount",
          "channel",
          "method"
        ],
        "properties": {
          "student_id": {
            "type": "integer",
            "minimum": 1
          },
          "amount": {
            "type": "number",
            "minimum": 1
          },
          "channel": {
            "type": "string",
            "example": "cash"
          },
          "method": {
            "type": "string",
            "example": "Tunai"
          },
          "reference": {
            "type": "string"
          },
          "bill_ids": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "is_bypass_rule": {
            "type": "boolean"
          }
        }
      },
      "PaymentIntentRequest": {
        "type": "object",
        "required": [
          "student_id",
          "amount",
          "bill_ids"
        ],
        "properties": {
          "student_id": {
            "type": "integer",
            "minimum": 1
          },
          "amount": {
            "type": "number",
            "minimum": 1
          },
          "bill_ids": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "is_bypass_rule": {
            "type": "boolean"
          }
        }
      },
      "SupportReplyRequest": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "security": [],
        "summary": "Login admin or parent",
        "responses": {
          "200": {
            "description": "Login success"
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/finance/bill-types": {
      "get": {
        "summary": "List bill types",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "summary": "Create bill type",
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/finance/billing-rules": {
      "get": {
        "summary": "List billing rules",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "summary": "Create billing rule",
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/finance/generate-bills": {
      "post": {
        "summary": "Generate student bills from one billing rule",
        "responses": {
          "200": {
            "description": "Generated"
          }
        }
      }
    },
    "/finance/generate-bills/bulk-cancel": {
      "post": {
        "summary": "Void generated bills; paid/partial amounts move to deposit",
        "responses": {
          "200": {
            "description": "Cancelled"
          }
        }
      }
    },
    "/finance/payments": {
      "post": {
        "summary": "Process manual/cash/deposit payment",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Processed"
          }
        }
      },
      "get": {
        "summary": "Get successful payment history by student_id",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/finance/payment-intent": {
      "post": {
        "summary": "Create Midtrans payment intent/order",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentIntentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Intent created"
          }
        }
      }
    },
    "/support/conversations": {
      "get": {
        "summary": "List WhatsApp CS conversations",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/support/conversations/{id}/messages": {
      "get": {
        "summary": "List messages in one CS conversation",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/support/conversations/{id}/reply": {
      "post": {
        "summary": "Reply to parent through official school WhatsApp session",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SupportReplyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sent"
          }
        }
      }
    },
    "/whatsapp/status": {
      "get": {
        "summary": "Get WAHA session status",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  }
}